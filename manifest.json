{
  "manifest_version": 3,
  "name": "Hypurr Extension",
  "description": "Hyperliquid trading support extension",
  "version": "0.2.0",
  "permissions": ["sidePanel", "tabs", "storage"],
  "host_permissions": [
    "https://api.hyperliquid.xyz/*",
    "https://api-ui.hyperliquid.xyz/*",
    "https://app.hyperliquid.xyz/*",
    "https://fapi.binance.com/*",
    "https://api.bybit.com/*",
    "https://api.hypurrscan.io/*",
    "https://api.hyperdash.com/*",
    "https://gql.opensea.io/*",
    "https://www.okx.com/*",
    "https://fapi.asterdex.com/*",
    "https://mainnet.zklighter.elliot.ai/*",
    "https://api.pacifica.fi/*",
    "https://api.starknet.extended.exchange/*",
    "https://pro.edgex.exchange/*",
    "https://edgex-prod-v2.edgex.exchange/*",
    "https://market-data.grvt.io/*",
    "https://omni-client-api.prod.ap-northeast-1.variational.io/*",
    "https://query1.finance.yahoo.com/*",
    "https://query2.finance.yahoo.com/*",
    "https://fc.yahoo.com/*",
    "https://streamer.finance.yahoo.com/*",
    "https://capi.coinglass.com/*",
    "https://farside.co.uk/*",
    "https://news.google.com/*",
    "https://data.strategytracker.com/*",
    "https://api.coingecko.com/*",
    "https://gamma-api.polymarket.com/*",
    "https://api-boros.pendle.finance/*"
  ],
  "action": {
    "default_title": "Open Hypurr Extension"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://app.hyperliquid.xyz/*"],
      "js": ["src/content/hlWallet.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["https://app.hyperliquid.xyz/*"]
    }
  ],
  "icons": {
    "16": "public/icon16.png",
    "48": "public/icon48.png",
    "128": "public/icon128.png"
  }
}
